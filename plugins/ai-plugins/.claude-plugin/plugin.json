{
  "name": "ai-plugins",
  "version": "2.1.0",
  "description": "Endor Labs Agent Kit setup and security workflow agents and skills for Cursor.",
  "updatedAt": "2026-07-13T00:01:09.704Z",
  "author": {
    "url": "https://www.endorlabs.com/",
    "name": "Endor Labs",
    "email": "support@endor.ai"
  },
  "homepage": "https://endorlabs.com",
  "repository": "https://github.com/endorlabs/ai-plugins",
  "keywords": [
    "endor-labs",
    "security",
    "dependencies",
    "endorctl",
    "sca",
    "sast",
    "agentic remediation",
    "AppSec"
  ],
  "skills": "./skills/",
  "agents": "./agents/",
  "hooks": {
    "afterFileEdit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/check-manifest-edit.sh afterFileEdit"
          }
        ]
      }
    ],
    "beforeShellExecution": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/check-dep-install.sh beforeShellExecution"
          }
        ]
      }
    ],
    "beforeSubmitPrompt": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/suggest-endor-tools.sh beforeSubmitPrompt"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "endor-cli-tools": {
      "args": [
        "-y",
        "endorctl",
        "ai-tools",
        "mcp-server"
      ],
      "type": "stdio",
      "command": "npx"
    }
  }
}