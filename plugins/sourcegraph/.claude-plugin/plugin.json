{
  "name": "sourcegraph",
  "version": "1.0.0",
  "description": "Use Sourcegraph MCP from Claude Code for code search, navigation, history, and Deep Search.",
  "author": {
    "name": "Sourcegraph Community"
  },
  "homepage": "https://github.com/sourcegraph-community/sourcegraph-claudecode-plugin",
  "repository": "https://github.com/sourcegraph-community/sourcegraph-claudecode-plugin",
  "skills": "./skills/",
  "mcpServers": {
    "sourcegraph": {
      "url": "${SOURCEGRAPH_ENDPOINT}/.api/mcp",
      "type": "http",
      "headers": {
        "Authorization": "token ${SOURCEGRAPH_ACCESS_TOKEN}"
      }
    }
  }
}