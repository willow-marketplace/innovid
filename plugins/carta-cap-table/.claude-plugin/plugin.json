{
  "name": "carta-cap-table",
  "version": "6.24.2",
  "description": "Carta Cap Table plugin — skills and hooks for querying cap tables, grants, SAFEs, 409A valuations, waterfall scenarios, and more",
  "updatedAt": "2026-07-13T00:01:49.405Z",
  "author": {
    "name": "Carta",
    "email": "engineering@carta.com"
  },
  "homepage": "https://github.com/carta/plugins",
  "repository": "https://github.com/carta/plugins",
  "keywords": [
    "cap_table",
    "mcp",
    "carta",
    "equity",
    "grants"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/inject-skill-context.js\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/init-data-dir.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/track-active-skill.js\""
          }
        ]
      },
      {
        "matcher": "mcp__(plugin_.*[Cc]arta.*|carta.*|Carta.*|2827383e-1775-4df3-b6ff-04d5392f6d18|640916d9-5e0c-4d0b-830a-03500fa93e5e|1af3c326-9402-463c-ba5c-d62de59cf57b|8eb65db0-0cbd-4f50-833b-3057c150d41a|33b9b857-8443-4b2d-b191-2d9b6c50eb86)__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/inject-instrumentation.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/track-slash-skill.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__(plugin_.*[Cc]arta.*|carta.*|Carta.*|2827383e-1775-4df3-b6ff-04d5392f6d18|640916d9-5e0c-4d0b-830a-03500fa93e5e|1af3c326-9402-463c-ba5c-d62de59cf57b|8eb65db0-0cbd-4f50-833b-3057c150d41a|33b9b857-8443-4b2d-b191-2d9b6c50eb86)__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-tool-tracker.js\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "carta": {
      "url": "https://mcp.app.carta.com/mcp",
      "type": "http"
    }
  }
}