{
  "name": "semgrep",
  "version": "2.0.3",
  "description": "Semgrep Guardian: Scans agent-generated code for security vulnerabilities.",
  "updatedAt": "2026-07-14T00:01:51.219Z",
  "author": {
    "url": "https://github.com/semgrep",
    "name": "Semgrep"
  },
  "homepage": "https://github.com/semgrep/mcp-marketplace.git",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook.sh claude PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook.sh claude PostToolUse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook.sh claude SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook.sh claude UserPromptSubmit"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "guardian": {
      "args": [
        "claude",
        "mcp"
      ],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook.sh"
    }
  }
}