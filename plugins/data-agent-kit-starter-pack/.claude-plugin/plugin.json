        "CLOUD_SQL_POSTGRES_DATABASE": "",
        "CLOUD_SQL_POSTGRES_INSTANCE": "",
        "CLOUD_SQL_POSTGRES_PASSWORD": ""
      },
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "cloud-sql-postgres",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "command": "npx"
    },
    "alloydb-postgres-admin": {
      "env": {},
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "alloydb-postgres-admin",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
