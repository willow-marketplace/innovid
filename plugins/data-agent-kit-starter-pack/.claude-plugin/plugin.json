{
  "name": "data-agent-kit-starter-pack",
  "version": "0.6.1",
  "description": "This plugin provides a specialized suite of skills for data engineers and database practitioners working on Google Cloud. It acts as an expert assistant, allowing you to use natural language prompts in your preferred coding agent to architect complex data pipelines, transform data with dbt, write Spark and BigQuery SQL notebooks, and orchestrate end-to-end workflows across GCP's data ecosystem.",
  "updatedAt": "2026-07-13T00:00:31.993Z",
  "author": {
    "name": "Google LLC",
    "email": "data-cloud-ai-integrations@google.com"
  },
  "skills": "./skills/",
  "mcpServers": {
    "spanner": {
      "env": {
        "SPANNER_DIALECT": "",
        "SPANNER_PROJECT": "$PROJECT_ID",
        "SPANNER_DATABASE": "",
        "SPANNER_INSTANCE": ""
      },
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "spanner",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "command": "npx"
    },
    "bigquery": {
      "env": {
        "BIGQUERY_PROJECT": "$PROJECT_ID",
        "BIGQUERY_LOCATION": "$BIGQUERY_LOCATION"
      },
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "bigquery",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "command": "npx"
    },
    "dataproc": {
      "env": {
        "DATAPROC_REGION": "$GCP_REGION",
        "DATAPROC_PROJECT": "$PROJECT_ID"
      },
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "dataproc",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "command": "npx"
    },
    "notebook": {
      "env": {},
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=notebook"
      ],
      "command": "npx",
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "visualization": {
      "env": {},
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=visualization"
      ],
      "command": "npx",
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "alloydb-postgres": {
      "env": {
        "ALLOYDB_POSTGRES_USER": "",
        "ALLOYDB_POSTGRES_REGION": "$GCP_REGION",
        "ALLOYDB_POSTGRES_CLUSTER": "",
        "ALLOYDB_POSTGRES_IP_TYPE": "",
        "ALLOYDB_POSTGRES_PROJECT": "$PROJECT_ID",
        "ALLOYDB_POSTGRES_DATABASE": "",
        "ALLOYDB_POSTGRES_INSTANCE": "",
        "ALLOYDB_POSTGRES_PASSWORD": ""
      },
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "alloydb-postgres",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "command": "npx"
    },
    "serverless-spark": {
      "env": {
        "SERVERLESS_SPARK_PROJECT": "$PROJECT_ID",
        "SERVERLESS_SPARK_LOCATION": "$GCP_REGION"
      },
      "args": [
