{
  "mcpServers": {
    "terraform": {
      "env": {
        "TFE_TOKEN": "${TFE_TOKEN}",
        "TFE_ADDRESS": "${TFE_ADDRESS}"
      },
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "TFE_TOKEN",
        "-e",
        "TFE_ADDRESS",
        "hashicorp/terraform-mcp-server"
      ],
      "command": "docker"
    }
  }
}