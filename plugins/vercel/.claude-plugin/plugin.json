{
  "name": "vercel",
  "version": "1.0.0",
  "description": "Build and deploy web apps and agents",
  "updatedAt": "2026-07-09T15:06:04.730Z",
  "author": {
    "url": "https://github.com/vercel",
    "name": "Vercel"
  },
  "homepage": "https://github.com/vercel/vercel-plugin",
  "repository": "https://github.com/vercel/vercel-plugin",
  "keywords": [
    "vercel",
    "nextjs",
    "ai-sdk",
    "turborepo",
    "turbopack",
    "workflow",
    "deployment",
    "serverless"
  ],
  "skills": "./skills/",
  "commands": "./commands/",
  "agents": "./agents/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-seen-skills.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-profiler.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/inject-claude-md.mjs\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-cleanup.mjs\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "vercel": {
      "url": "https://mcp.vercel.com",
      "note": "Official Vercel MCP server. Uses OAuth — on first connection the agent will be prompted to authorize via Vercel. Read-only in initial release: search docs, list projects/deployments, inspect logs.",
      "type": "http"
    }
  }
}