{
  "name": "astronomer-data-agents",
  "version": "0.1.0",
  "description": "Data engineering plugin - warehouse exploration, pipeline authoring, Airflow integration",
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "command": "${CLAUDE_PLUGIN_ROOT}/skills/airflow/hooks/warm-uvx-cache.sh"
      }
    ],
    "Stop": [
      {
        "command": "uv run ${CLAUDE_PLUGIN_ROOT}/skills/analyzing-data/scripts/cli.py stop"
      }
    ]
  }
}