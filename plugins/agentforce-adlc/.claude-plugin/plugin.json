{
  "name": "agentforce-adlc",
  "version": "0.9.0",
  "description": "Agentforce Agent Development Life Cycle — author, discover, scaffold, deploy, test, secure, and optimize .agent files",
  "updatedAt": "2026-07-09T15:03:34.686Z",
  "author": {
    "name": "SalesforceAIResearch"
  },
  "repository": "https://github.com/SalesforceAIResearch/agentforce-adlc",
  "keywords": [
    "agentforce",
    "agent-script",
    "salesforce",
    "adlc"
  ],
  "skills": "./skills/",
  "agents": "./agents/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/shared/hooks/scripts/guardrails.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/shared/hooks/scripts/agent-validator.py"
          }
        ]
      }
    ]
  }
}