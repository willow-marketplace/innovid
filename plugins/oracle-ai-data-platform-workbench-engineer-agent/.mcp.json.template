{
  "_comment": "OPTIONAL — the plugin does NOT require an MCP. It is fully self-contained (oci raw-request + scripts/aidp_sql.py). This template is only for users who want to wire an AIDP MCP as an optional accelerator: fill the placeholders from ~/.oci/config + your DataLake/workspace and save as .mcp.json (NEVER commit it — .gitignored). The aidp MCP package, if used, comes from amitranjan-oracle/ai-data-engineer-agent.",
  "mcpServers": {
    "aidp": {
      "command": "python",
      "args": ["-m", "aidp_agent.mcp_server"],
      "_command_alt_when_published_to_pypi": ["uvx", "aidp-mcp"],
      "cwd": "${AIDP_AGENT_REPO_PATH}",
      "env": {
        "AIDP_REGION": "${AIDP_REGION}",
        "AIDP_DATA_LAKE_ID": "${AIDP_DATA_LAKE_ID}",
        "AIDP_WORKSPACE_ID": "${AIDP_WORKSPACE_ID}",
        "AIDP_AUTH_TYPE": "${AIDP_AUTH_TYPE}",
        "OCI_BASE_CONFIG_PROFILE": "${OCI_BASE_CONFIG_PROFILE}",
        "AIDP_MCP_ENABLE_ADMIN_TOOLS": "${AIDP_MCP_ENABLE_ADMIN_TOOLS}"
      }
    }
  }
}
