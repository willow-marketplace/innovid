{
  "name": "render",
  "version": "1.0.0",
  "description": "Deploy, debug, and monitor applications on Render. Includes skills, an agent, slash commands, and a render.yaml validation hook.",
  "updatedAt": "2026-07-09T15:20:00.553Z",
  "author": {
    "url": "https://render.com",
    "name": "Render",
    "email": "support@render.com"
  },
  "homepage": "https://github.com/render-oss/render-plugin-claude-code",
  "repository": "https://github.com/render-oss/render-plugin-claude-code",
  "keywords": [
    "render",
    "deploy",
    "cloud",
    "blueprint",
    "monitoring",
    "debugging"
  ],
  "skills": "./skills/",
  "commands": "./commands/",
  "agents": "./agents/",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-render-yaml-hook.sh"
          }
        ]
      }
    ]
  }
}