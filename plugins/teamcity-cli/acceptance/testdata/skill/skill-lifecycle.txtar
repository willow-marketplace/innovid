# Test skill install, update, and remove lifecycle.

exec teamcity skill install --agent claude-code --project --no-input
stdout 'Installed'
! stderr 'Error'

# Update should report already up to date
exec teamcity skill update --agent claude-code --project --no-input
stdout 'up to date'
! stderr 'Error'

exec teamcity skill remove --agent claude-code --project --no-input
stdout 'Removed'
! stderr 'Error'

# Remove again should say not installed
exec teamcity skill remove --agent claude-code --project --no-input
stdout 'not installed'
! stderr 'Error'
