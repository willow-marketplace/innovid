# List favorite builds for the current user.
# Favorites are per-user state we can't bootstrap, so the assertions only verify
# the command exits cleanly — no content checks that would assume specific builds.
[!has_token] skip 'requires authentication token'

exec teamcity run list --favorites --limit 5 --no-input
! stderr 'Error'

exec teamcity run list --favorites --status success --limit 3 --no-input
! stderr 'Error'

exec teamcity run list --favorites --json --limit 10 --no-input
! stderr 'Error'

exec teamcity run list --favorites --plain --limit 3 --no-input
! stderr 'Error'

exec teamcity run list --favorites --user @me --limit 3 --no-input
! stderr 'Error'
