# Extended metadata tests: multi-tag, pin with comment verification.
[!has_token] skip 'requires authentication token'

# Find a different finished build than run-metadata uses (offset by 1)
exec teamcity api '/app/rest/builds?locator=start:1,count:1,state:finished&fields=build(id)' --raw --no-input
extract '"id":(\d+)' BUILD_ID

exec teamcity run tag $BUILD_ID tag-a-$RANDOM_STRING tag-b-$RANDOM_STRING tag-c-$RANDOM_STRING --no-input
stdout 'Added 3 tag'

exec teamcity run untag $BUILD_ID tag-a-$RANDOM_STRING tag-b-$RANDOM_STRING tag-c-$RANDOM_STRING --no-input
stdout 'Removed'

# Pin with comment, then verify comment via view
exec teamcity run pin $BUILD_ID --comment 'acceptance-pin-$RANDOM_STRING' --no-input
stdout 'Pinned'

exec teamcity run view $BUILD_ID --json --no-input
stdout '"pinned"'

exec teamcity run unpin $BUILD_ID --no-input
stdout 'Unpinned'

# Comment round-trip: set → read → overwrite → read → delete → read
exec teamcity run comment $BUILD_ID 'first-$RANDOM_STRING' --no-input
stdout 'Set comment'

exec teamcity run comment $BUILD_ID --no-input
stdout 'first-'

exec teamcity run comment $BUILD_ID 'second-$RANDOM_STRING' --no-input
stdout 'Set comment'

exec teamcity run comment $BUILD_ID --no-input
stdout 'second-'

exec teamcity run comment $BUILD_ID --delete --no-input
stdout 'Deleted comment'

exec teamcity run comment $BUILD_ID --no-input
stdout 'No comment'
