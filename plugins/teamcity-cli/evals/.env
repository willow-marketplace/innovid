# Secrets are resolved via 1Password CLI (`op run`).
# The justfile handles this automatically — just run `just eval`.
#
# To set up: create a 1Password item "teamcity-cli-evals" in the Private vault
# with fields: SENTRY_AUTH_TOKEN, CLAUDE_CODE_OAUTH_TOKEN, TEAMCITY_TOKEN
#
# Or override any value below with a literal to skip 1Password for that key.

# Sentry — DSN is public/ingest-only, safe to commit. It cannot read data back,
# so automated compare needs a Bearer auth token (event:read + org:read) plus
# the org slug. Without them, scripts/compare.py falls back to local-dir diff.
SENTRY_DSN=https://ba1204a9ceb0f6e1a9683ebb02feebf8@o629866.ingest.us.sentry.io/4511235077373952
# SENTRY_ORG=op://Private/teamcity-cli-evals/SENTRY_ORG
# SENTRY_AUTH_TOKEN=op://Private/teamcity-cli-evals/SENTRY_AUTH_TOKEN
SENTRY_ENVIRONMENT=eval

# Langfuse — public key + host are not secret (ingest-only), safe to commit.
# Secret key is resolved via 1Password like the other secrets.
LANGFUSE_PUBLIC_KEY=pk-lf-72b7aae6-aadf-485d-bbad-0a0a09b1a54f
LANGFUSE_HOST=https://langfuse.labs.jb.gg
LANGFUSE_SECRET_KEY=op://Private/teamcity-cli-evals/LANGFUSE_SECRET_KEY

# Anthropic — at least one of these, or Claude Code CLI OAuth login.
# Priority: ANTHROPIC_API_KEY → CLAUDE_CODE_OAUTH_TOKEN → CLI OAuth.
ANTHROPIC_API_KEY=op://Private/teamcity-cli-evals/ANTHROPIC_API_KEY
# CLAUDE_CODE_OAUTH_TOKEN — 403s for org-managed accounts without Claude Code
# API access; prefer the API key.
# CLAUDE_CODE_OAUTH_TOKEN=op://Private/teamcity-cli-evals/CLAUDE_CODE_OAUTH_TOKEN
# ANTHROPIC_BASE_URL="http://claude-code-proxy"

# TeamCity server for eval tasks
TEAMCITY_URL=https://buildserver.labs.intellij.net
TEAMCITY_TOKEN=op://Private/teamcity-cli-evals/TEAMCITY_TOKEN

# Eval configuration
# Model to test (change to compare: claude-sonnet-4-5-20250929, claude-opus-4-6, claude-haiku-4-5-20251001)
BENCH_CC_MODEL=claude-sonnet-4-5-20250929
BENCH_TIMEOUT=300
# Set to 1 to run Claude Code locally instead of Docker
# BENCH_LOCAL=1
