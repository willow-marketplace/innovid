{
  "name": "aws-serverless",
  "version": "1.3.0",
  "description": "Design, build, deploy, test, and debug serverless applications with AWS Serverless services.",
  "updatedAt": "2026-07-12T12:00:16.227Z",
  "author": {
    "name": "Amazon Web Services"
  },
  "homepage": "https://github.com/awslabs/agent-plugins",
  "repository": "https://github.com/awslabs/agent-plugins",
  "keywords": [
    "aws",
    "lambda",
    "durable functions",
    "managed-instances",
    "lmi",
    "serverless",
    "development",
    "sam",
    "api-gateway",
    "eventbridge",
    "step-functions",
    "microvms",
    "firecracker"
  ],
  "skills": "./skills/",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/validate-template.sh\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "aws-serverless-mcp": {
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "args": [
        "awslabs.aws-serverless-mcp-server@latest",
        "--allow-write"
      ],
      "command": "uvx",
      "timeout": 120000
    }
  }
}