{
  "name": "grafana-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI-assisted Grafana dashboard, datasource, alerting, and incident management.",
  "updatedAt": "2026-07-13T12:01:58.837Z",
  "author": {
    "name": "Grafana Labs",
    "email": "grafana-assistant@grafana.com"
  },
  "homepage": "https://github.com/grafana/ai-marketplace/tree/main/plugins/grafana-mcp",
  "repository": "https://github.com/grafana/ai-marketplace",
  "keywords": [
    "grafana",
    "mcp",
    "observability",
    "dashboards",
    "prometheus",
    "loki"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "grafana": {
      "env": {
        "GRAFANA_URL": "${user_config.grafana_url}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${user_config.grafana_service_account_token}"
      },
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "-t",
        "stdio"
      ],
      "command": "docker"
    }
  }
}