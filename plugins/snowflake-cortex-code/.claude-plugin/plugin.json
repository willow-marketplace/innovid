{
  "name": "snowflake-cortex-code",
  "version": "3.2.3",
  "description": "Automatically route Snowflake prompts from Claude Code to Cortex Code for execution.",
  "updatedAt": "2026-07-13T00:02:04.966Z",
  "author": {
    "name": "Snowflake"
  },
  "homepage": "https://docs.snowflake.com/en/user-guide/cortex-code/cortex-code",
  "repository": "https://github.com/Snowflake-Labs/snowflake-ai-kit",
  "keywords": [
    "snowflake",
    "cortex-code",
    "auto-routing",
    "sql",
    "data"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/router/discover_cortex.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/router/discover_cortex.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/router/prompt_filter.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/router/prompt_filter.py\""
          }
        ]
      }
    ]
  }
}